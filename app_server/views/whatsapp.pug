extends layout

block content
  .container-fluid.p-0.module-shell
    .p-4.text-white.module-header(style=`background:${themeColor || '#25D366'}; border-bottom-left-radius:40px; border-bottom-right-radius:40px;`)
      .module-header-inner
        .d-flex.align-items-center.justify-content-between.flex-wrap.gap-3
          a.text-white.text-decoration-none(href=volverHref style="font-size:1.15rem;")
            i.bi.bi-arrow-left.me-2
            | Volver
          .fw-semibold(style="font-size:1.1rem;") #{completedCount} de #{totalCount} completados

        .d-flex.align-items-center.mt-4
          .bg-white.rounded-4.d-flex.justify-content-center.align-items-center.me-3.module-main-icon(style="width:82px; height:82px; min-width:82px;")
            i.bi(class=themeIcon || 'bi-chat-left-text-fill', style=`font-size:2.3rem; color:${themeColor || '#25D366'};`)
          .flex-grow-1
            h2.fw-bold.m-0(style="font-size:2rem;")= title
            .progress.mt-3(style="height:12px; border-radius:10px;")
              - const pct = Math.round((completedCount / totalCount) * 100)
              .progress-bar(role="progressbar", style=`width:${pct}%; background:${themeColor || '#25D366'};`)

    .px-3.mt-4.pb-5.module-content
      .module-content-inner
        .card.border-0.shadow-sm.p-4.mb-4(style=`border-radius:20px; border-left:8px solid ${themeAccent || '#1f9f4d'} !important;`)
          h3.fw-bold.mb-2(style=`color:${themeAccent || '#1f9f4d'}; font-size:1.45rem;`) Ejercicios prÃ¡cticos
          p.text-muted.m-0(style="font-size:1.08rem; line-height:1.6;") Completa cada ejercicio en orden. AprenderÃ¡s realizando acciones reales paso a paso.

        .exercise-list
          each ej in ejercicios
            - const cardCls = ej.locked ? 'locked' : ''
            a.text-decoration-none(href=ej.href)
              .card.border-0.shadow-sm.mb-3.exercise-card(class=cardCls, style="border-radius:20px;")
                .p-4.d-flex.align-items-start
                  if ej.completed
                    .rounded-circle.d-flex.justify-content-center.align-items-center.me-3(style=`width:52px; height:52px; background:${themeColor || '#25D366'}; min-width:52px;`)
                      i.bi.bi-check-lg(style="font-size:1.7rem; color:#fff;")
                  else
                    .rounded-circle.d-flex.justify-content-center.align-items-center.me-3(style=`width:52px; height:52px; background:${themeLight || '#e8f7ee'}; border:3px solid ${themeColor || '#25D366'}; min-width:52px;`)
                      span.fw-bold(style=`color:${themeColor || '#25D366'}; font-size:1.15rem;`)= ej.orden
                  .flex-grow-1
                    h4.fw-bold.mb-2.text-dark(style="font-size:1.35rem;")= ej.nombre
                    p.text-muted.m-0(style="font-size:1.08rem; line-height:1.6;")= ej.desc
                    if ej.locked
                      p.text-muted.mt-3.mb-0(style="font-size:1.02rem;") Completa el ejercicio anterior primero
                    if ej.completed
                      span.badge.rounded-pill.mt-3(style=`background:${themeLight || '#e8f7ee'}; color:${themeAccent || '#1f9f4d'}; border:1px solid #bfe9cf; font-size:1rem; padding:8px 14px;`) âœ“ Completado
