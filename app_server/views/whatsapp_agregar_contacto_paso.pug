extends layout

block content
  .container-fluid.p-0.lesson-shell
    .p-4.text-white.lesson-header(style=`background:${themeColor || '#25D366'}; border-bottom-left-radius:40px; border-bottom-right-radius:40px;`)
      .lesson-header-inner
        a.text-white.text-decoration-none(href=volverHref style="font-size:1.15rem;")
          i.bi.bi-arrow-left.me-2
          | Volver

        h2.fw-bold.mt-4.mb-2(style="font-size:2rem;")= title
        p.m-0(style="font-size:1.12rem; line-height:1.6;") Aprende paso a paso dentro de #{modulo}

        .progress.mt-3(style="height:12px; border-radius:10px;")
          - const pct = Math.round((paso / totalPasos) * 100)
          .progress-bar(role="progressbar", style=`width:${pct}%; background:#fff; opacity:0.9;`)

    .px-3.mt-4.pb-5.lesson-content
      .lesson-content-inner

        .card.border-0.shadow-sm.p-4.mb-3.lesson-card(style="border-radius:20px;")
          .d-flex.align-items-start
            .rounded-circle.d-flex.justify-content-center.align-items-center.me-3.lesson-step-circle(
              style=`width:54px; height:54px; background:${themeLight || '#e8f7ee'}; border:3px solid ${themeColor || '#25D366'}; min-width:54px;`
            )
              span.fw-bold(style=`color:${themeColor || '#25D366'};`)= paso

            .flex-grow-1
              h3.h6.fw-bold.mb-2.text-dark= titulo
              p.small.m-0
                span.text-muted= instruccion
                span.fw-bold(style="color:#C0392B;")= accion

        if imagenRuta
          .card.border-0.shadow-sm.p-4.mb-3.lesson-card(style=`border-radius:20px; background:${themeLight || '#eef8ff'}; border:1px solid #dbe7ef;`)
            h4.h6.fw-bold.mb-3(style=`color:${themeAccent || '#0D6EFD'};`) Imagen de apoyo
            .text-center
              img.img-fluid.rounded.shadow-sm.mb-3(
                src=imagenRuta
                alt=imagenAlt || 'Imagen de apoyo'
                style="max-height:260px; object-fit:contain;"
              )

        if explicacion
          .card.border-0.shadow-sm.p-4.mb-3.lesson-card(style="border-radius:20px; background:#eef8ff; border:1px solid #cfe8ff;")
            h4.h6.fw-bold.mb-2(style="color:#0D6EFD;")= explicacion.titulo
            p.text-muted.small.m-0= explicacion.texto

        if videoUrl
          .card.border-0.shadow-sm.p-4.mb-3.lesson-card(style="border-radius:20px; background:#fff;")
            h4.h6.fw-bold.mb-3 Video de apoyo
            .ratio.ratio-16x9
              iframe(
                src=videoUrl
                title="Video explicativo"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              )

        if tipo === 'tap' && juego
          .card.border-0.shadow-sm.p-4.mb-3.lesson-card.lesson-game-card(
            style="border-radius:20px; background:#fff7dc; border:1px solid #f2e2a5;"
            data-minigame="tap"
          )
            .text-center
              i.bi.bi-hand-index-thumb(style="font-size:2.2rem; color:#4b4b4b;")
              p.fw-semibold.mt-3.mb-4= juego.instruccion

            .d-grid.gap-3.lesson-options
              each opcion in juego.opciones
                button.btn.btn-outline-success.btn-lg.rounded-pill.py-3(
                  type="button"
                  data-option
                  data-correct=opcion.correcta ? 'true' : 'false'
                )= opcion.texto

            .mt-3(data-feedback)

            button.btn.btn-outline-secondary.w-100.rounded-pill.mt-3.py-3.d-none(
              type="button"
              data-retry-button
            ) Intentar de nuevo

        if tipo === 'input' && juego
          .card.border-0.shadow-sm.p-4.mb-3.lesson-card.lesson-game-card(
            style="border-radius:20px; background:#fff7dc; border:1px solid #f2e2a5;"
            data-minigame="input"
          )
            .text-center
              i.bi.bi-pencil-square(style="font-size:2.2rem; color:#4b4b4b;")
              p.fw-semibold.mt-3.mb-4= juego.instruccion

            input.form-control.form-control-lg.rounded-pill.mb-3.py-3(
              type="text"
              placeholder=juego.placeholder
              data-input-answer
            )

            button.btn.btn-outline-primary.w-100.rounded-pill.py-3(
              type="button"
              data-check-input
              data-correct-answer=juego.respuestaCorrecta
            )= juego.botonTexto || 'Comprobar'

            .mt-3(data-feedback)

            button.btn.btn-outline-secondary.w-100.rounded-pill.mt-3.py-3.d-none(
              type="button"
              data-retry-input
            ) Intentar de nuevo

        if tipo !== 'tap' && tipo !== 'input'
          .card.border-0.shadow-sm.p-4.mb-3.lesson-card(style="border-radius:20px; background:#fff7dc; border:1px solid #f2e2a5;")
            .text-center
              i.bi.bi-grid-3x3-gap-fill(style="font-size:2.2rem; color:#4b4b4b;")
              p.fw-semibold.mt-3.mb-0= simulacion

        a.btn.btn-success.w-100.rounded-pill.py-3.fw-bold.mt-2.lesson-next-btn(
          href=nextHref
          data-next-button
          style=`background:${themeColor || '#25D366'}; border-color:${themeColor || '#25D366'};`
        ) Realizar acción

block scripts
  script(src="/javascripts/minijuegos.js")